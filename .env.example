# Silver Command Center Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# FRED API Key (free — register at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# X/Twitter API Bearer Token (optional — for live sentiment monitoring)
# Get yours at https://developer.twitter.com/
X_BEARER_TOKEN=

# Data refresh interval in minutes (default: 30)
REFRESH_INTERVAL_MINUTES=30

# Data directory (default: ./data)
DATA_DIR=./data
